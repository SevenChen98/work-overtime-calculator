{
  "name": "overtime-tracker-app",
  "private": true,
  "version": "1.0.0",
  "description": "Desktop overtime tracker for monthly work-hour logging.",
  "author": "Codex",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:web\" \"npm:dev:server\"",
    "dev:web": "vite",
    "dev:server": "node server.js",
    "dev:desktop": "concurrently \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:electron": "wait-on tcp:5173 && electron .",
    "build": "vite build",
    "build:desktop": "npm run build && electron-packager . \"加班工时计算器\" --platform=win32 --arch=x64 --out=release --overwrite --prune=true --ignore=\"^/data($|/)\" --ignore=\"^/release($|/)\" --ignore=\"^/src($|/)\" --ignore=\"^/\\.git($|/)\" --ignore=\"^/node_modules/\\.cache($|/)\"",
    "start": "node server.js"
  },
  "main": "electron/main.cjs",
  "dependencies": {
    "express": "^4.21.2",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "@electron/packager": "^18.3.6",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.19",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.local.overtime.tracker",
    "productName": "加班工时计算器",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
