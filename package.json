{
  "name": "overtime-tracker-app",
  "private": true,
  "version": "1.0.1",
  "description": "Desktop overtime tracker for monthly work-hour logging.",
  "author": "Codex",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:web\" \"npm:dev:server\"",
    "dev:web": "vite",
    "dev:server": "node server.js",
    "dev:desktop": "set \"PATH=%USERPROFILE%\\.cargo\\bin;%PATH%\" && tauri dev",
    "build": "vite build",
    "build:desktop": "set \"PATH=%USERPROFILE%\\.cargo\\bin;%PATH%\" && tauri build --bundles nsis",
    "start": "node server.js",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "express": "^4.21.2",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.0",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.19"
  }
}
